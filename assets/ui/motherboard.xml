[ignoring loop detection]
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 400" width="100%" height="100%">
  <!-- Sleek Solarized Dark PCB Base -->
  <rect width="800" height="400" rx="14" fill="#002b36" stroke="#586e75" stroke-width="2.5" />
  
  <!-- Complex High-Fidelity Circuit Traces (Background Aesthetics) -->
  <g stroke="#2aa198" stroke-width="1.2" opacity="0.12" fill="none" pointer-events="none">
    <path d="M 0 50 L 800 50 M 0 100 L 800 100 M 0 150 L 800 150 M 0 200 L 800 200 M 0 250 L 800 250 M 0 300 L 800 300 M 0 350 L 800 350" />
    <path d="M 100 0 L 100 400 M 200 0 L 200 400 M 300 0 L 300 400 M 400 0 L 400 400 M 500 0 L 500 400 M 600 0 L 600 400 M 700 0 L 700 400" />
    <path d="M 30 40 L 90 100 L 180 100 M 90 100 L 90 220" />
    <path d="M 770 360 L 710 300 L 600 300" />
    <path d="M 360 40 L 410 90 L 410 210" />
    <path d="M 500 350 L 540 310 L 670 310" />
    <path d="M 220 380 L 250 350 L 390 350" />
  </g>

  <!-- Gold PCB Mounting Screws -->
  <g fill="#b58900" stroke="#073642" stroke-width="2" opacity="0.8">
    <circle cx="30" cy="30" r="6" />
    <circle cx="770" cy="30" r="6" />
    <circle cx="30" cy="370" r="6" />
    <circle cx="770" cy="370" r="6" />
  </g>

  <!-- ========================================================================= -->
  <!-- HIGHWAY INTERACTIVE SYSTEM DATA BUS TRACES (ANIMATABLE NEON FLOWS)        -->
  <!-- ========================================================================= -->
  <path id="bus-ssd-chipset" class="mobo-bus" d="M 190 205 L 315 205" />
  <path id="bus-chipset-ram" class="mobo-bus" d="M 370 170 L 370 135 L 440 135" />
  <path id="bus-ram-chipset" class="mobo-bus" d="M 440 145 L 380 145 L 380 200 L 370 200" />
  <path id="bus-chipset-cpu" class="mobo-bus" d="M 425 205 L 585 205" />

  <!-- ========================================================================= -->
  <!-- COMPONENT 1: DETAILED M.2 NVME SSD CARD                                   -->
  <!-- ========================================================================= -->
  <g id="part-ssd">
    <!-- Component Slot Boundary -->
    <rect class="mobo-part" x="30" y="50" width="160" height="290" rx="10" />
    
    <!-- Motherboard M.2 Socket Connector (Right Side) -->
    <rect x="180" y="110" width="12" height="170" rx="3" fill="#073642" stroke="#586e75" stroke-width="1.5" />
    
    <!-- M.2 SSD PCB (slotted into the socket) -->
    <g transform="translate(38, 60)">
      <!-- SSD Card Body -->
      <rect width="142" height="270" rx="6" fill="#073642" stroke="#2aa198" stroke-width="1.8" />
      
      <!-- Keyed Gold Fingers (Right Edge Pin Contacts inside connector) -->
      <line x1="142" y1="50" x2="142" y2="220" stroke="#b58900" stroke-width="4.5" stroke-dasharray="4 2" />
      
      <!-- Left side semi-circular mounting notch -->
      <path d="M 0 125 A 10 10 0 0 1 0 145 Z" fill="#002b36" stroke="#2aa198" stroke-width="1.8" />
      <!-- Gold washer & Silver Motherboard Lock Screw -->
      <circle cx="0" cy="135" r="8" fill="#b58900" />
      <circle cx="0" cy="135" r="4.5" fill="#93a1a1" stroke="#586e75" stroke-width="1.5" />
      
      <!-- NAND Flash Memory Chip 0 -->
      <rect x="20" y="25" width="55" height="75" rx="3" fill="#002b36" stroke="#93a1a1" stroke-width="1.2" />
      <path d="M 20 37 L 75 37 M 20 49 L 75 49 M 20 61 L 75 61" stroke="#586e75" stroke-width="1" />
      <text x="47.5" y="75" fill="#93a1a1" font-family="monospace" font-size="11" font-weight="bold" text-anchor="middle">NAND 0</text>
      
      <!-- NAND Flash Memory Chip 1 -->
      <rect x="20" y="125" width="55" height="75" rx="3" fill="#002b36" stroke="#93a1a1" stroke-width="1.2" />
      <path d="M 20 137 L 75 137 M 20 149 L 75 149 M 20 161 L 75 161" stroke="#586e75" stroke-width="1" />
      <text x="47.5" y="175" fill="#93a1a1" font-family="monospace" font-size="11" font-weight="bold" text-anchor="middle">NAND 1</text>
      
      <!-- SSD Controller CPU & Controller RAM Cache -->
      <rect x="85" y="60" width="45" height="45" rx="4" fill="#586e75" stroke="#cb4b16" stroke-width="2" />
      <text x="107.5" y="86" fill="#fdf6e3" font-family="monospace" font-size="10" font-weight="bold" text-anchor="middle">CTRL</text>
      
      <rect x="85" y="130" width="45" height="24" rx="2.5" fill="#002b36" stroke="#93a1a1" stroke-width="1.2" />
      <text x="107.5" y="146" fill="#93a1a1" font-family="monospace" font-size="9" text-anchor="middle">CACHE</text>
      
      <!-- M.2 Branding Label -->
      <text x="71" y="235" fill="#2aa198" font-family="monospace" font-size="12" font-weight="bold" text-anchor="middle">SSD NVMe M.2</text>
      <text x="71" y="252" fill="#93a1a1" font-family="monospace" font-size="11" text-anchor="middle">Stockage Principal</text>
    </g>
  </g>

  <!-- ========================================================================= -->
  <!-- COMPONENT 2: CENTRAL PROCESSOR CHIPSET ROUTING HUB                        -->
  <!-- ========================================================================= -->
  <g id="part-chipset">
    <!-- Component Chipset Area -->
    <rect class="mobo-part" x="315" y="150" width="110" height="110" rx="12" />
    
    <!-- Central Chipset body -->
    <g transform="translate(315, 150)">
      <!-- Copper Heatspreader base -->
      <rect x="10" y="10" width="90" height="90" rx="8" fill="#cb4b16" stroke="#b58900" stroke-width="1.8" />
      
      <!-- Metallic heatsink fins structure -->
      <g stroke="#002b36" stroke-width="2.5">
        <line x1="22" y1="20" x2="22" y2="90" />
        <line x1="34" y1="20" x2="34" y2="90" />
        <line x1="46" y1="20" x2="46" y2="90" />
        <line x1="58" y1="20" x2="58" y2="90" />
        <line x1="70" y1="20" x2="70" y2="90" />
        <line x1="82" y1="20" x2="82" y2="90" />
        <line x1="90" y1="20" x2="90" y2="90" />
      </g>
      
      <!-- Center Chip Label -->
      <rect x="20" y="40" width="70" height="30" rx="3.5" fill="#586e75" stroke="#93a1a1" stroke-width="1.2" />
      <text x="55" y="59" fill="#fdf6e3" font-family="monospace" font-size="11" font-weight="bold" text-anchor="middle">CHIPSET</text>
    </g>
  </g>

  <!-- ========================================================================= -->
  <!-- COMPONENT 3: 4 ACCURATE DUAL-CHANNEL DIMM RAM SLOTS                       -->
  <!-- ========================================================================= -->
  <g id="part-ram">
    <!-- RAM slots boundary -->
    <rect class="mobo-part" x="440" y="40" width="130" height="190" rx="10" />
    
    <!-- 4 Detailed RAM DIMM Rails -->
    <g transform="translate(440, 40)">
      <!-- DIMM Rails background outlines -->
      <rect x="12" y="20" width="106" height="16" rx="3" fill="#073642" stroke="#586e75" stroke-width="1.2" />
      <rect x="12" y="55" width="106" height="16" rx="3" fill="#073642" stroke="#586e75" stroke-width="1.2" />
      <rect x="12" y="90" width="106" height="16" rx="3" fill="#073642" stroke="#586e75" stroke-width="1.2" />
      <rect x="12" y="125" width="106" height="16" rx="3" fill="#073642" stroke="#586e75" stroke-width="1.2" />
      
      <!-- 4 Populated RAM Modules -->
      <g>
        <!-- Gold Contact Pins on the LEFT edge of each rail -->
        <line x1="14" y1="22" x2="14" y2="34" stroke="#b58900" stroke-width="2.5" stroke-dasharray="2 1" />
        <line x1="14" y1="57" x2="14" y2="69" stroke="#b58900" stroke-width="2.5" stroke-dasharray="2 1" />
        <line x1="14" y1="92" x2="14" y2="104" stroke="#b58900" stroke-width="2.5" stroke-dasharray="2 1" />
        <line x1="14" y1="127" x2="14" y2="139" stroke="#b58900" stroke-width="2.5" stroke-dasharray="2 1" />

        <!-- SMT Memory chips on each RAM module -->
        <g fill="#93a1a1">
          <!-- RAM Stick 1 chips -->
          <rect x="30" y="23" width="12" height="10" rx="1" />
          <rect x="52" y="23" width="12" height="10" rx="1" />
          <rect x="74" y="23" width="12" height="10" rx="1" />
          <rect x="96" y="23" width="12" height="10" rx="1" />

          <!-- RAM Stick 2 chips -->
          <rect x="30" y="58" width="12" height="10" rx="1" />
          <rect x="52" y="58" width="12" height="10" rx="1" />
          <rect x="74" y="58" width="12" height="10" rx="1" />
          <rect x="96" y="58" width="12" height="10" rx="1" />

          <!-- RAM Stick 3 chips -->
          <rect x="30" y="93" width="12" height="10" rx="1" />
          <rect x="52" y="93" width="12" height="10" rx="1" />
          <rect x="74" y="93" width="12" height="10" rx="1" />
          <rect x="96" y="93" width="12" height="10" rx="1" />

          <!-- RAM Stick 4 chips -->
          <rect x="30" y="128" width="12" height="10" rx="1" />
          <rect x="52" y="128" width="12" height="10" rx="1" />
          <rect x="74" y="128" width="12" height="10" rx="1" />
          <rect x="96" y="128" width="12" height="10" rx="1" />
        </g>
      </g>
      
      <!-- Side lock clips -->
      <rect x="6" y="16" width="6" height="24" fill="#586e75" rx="1.5" />
      <rect x="118" y="16" width="6" height="24" fill="#586e75" rx="1.5" />
      <rect x="6" y="121" width="6" height="24" fill="#586e75" rx="1.5" />
      <rect x="118" y="121" width="6" height="24" fill="#586e75" rx="1.5" />
      
      <!-- Label -->
      <text x="65" y="172" fill="#93a1a1" font-family="monospace" font-size="12" font-weight="bold" text-anchor="middle">RAM (DDR4)</text>
    </g>
  </g>

  <!-- ========================================================================= -->
  <!-- COMPONENT 4: MULTI-CORE CPU CORE SOCKET & CACHE HIERARCHY                 -->
  <!-- ========================================================================= -->
  <g id="part-cpu">
    <!-- CPU Slot Interaction Boundary -->
    <rect class="mobo-part" x="585" y="45" width="190" height="310" rx="14" />
    
    <!-- Complete CPU Socket Assembly -->
    <g transform="translate(585, 45)">
      <!-- Outer Metal Socket Frame -->
      <rect x="5" y="10" width="180" height="290" rx="8" fill="#586e75" stroke="#93a1a1" stroke-width="2.5" />
      
      <!-- Load Lever latch arm -->
      <rect x="177" y="20" width="6" height="230" fill="#93a1a1" rx="2" />
      <circle cx="180" cy="250" r="6" fill="#586e75" />
      
      <!-- Silicon Core Die (L2 Cache boundary outline) -->
      <rect id="cpu-die" class="cpu-die" x="18" y="20" width="154" height="225" rx="6" />
      
      <!-- 1. Shared Cache L3 block (located at the bottom of the die) -->
      <rect id="cpu-l3" class="cpu-l3-region" x="28" y="195" width="134" height="42" rx="3" />
      <text x="95" y="221" fill="#93a1a1" font-family="monospace" font-size="11" font-weight="bold" text-anchor="middle">CACHE L3 (PARTAGÉ)</text>
      
      <!-- 4 CPU Cores (Quadrant inside L2 Die) -->
      <!-- CORE 0 (Top-Left, hosts L1 cache & Registers) -->
      <g id="cpu-core-0">
        <!-- Core container -->
        <rect class="cpu-core" x="28" y="30" width="62" height="75" rx="3" />
        <text x="59" y="43" fill="#93a1a1" font-family="monospace" font-size="10" font-weight="bold" text-anchor="middle">CORE 0</text>
        
        <!-- Inner Core Cache Level 1 (L1) quadrant -->
        <rect id="cpu-l1" class="cpu-l1-region" x="32" y="50" width="24" height="48" rx="1.5" />
        <text x="44" y="78" fill="#fdf6e3" font-family="monospace" font-size="10" font-weight="bold" text-anchor="middle">L1</text>
        
        <!-- CPU Registers (Reg) block -->
        <rect id="cpu-reg" class="cpu-reg-region" x="62" y="50" width="24" height="48" rx="1.5" />
        <text x="74" y="78" fill="#268bd2" font-family="monospace" font-size="10" font-weight="bold" text-anchor="middle">REG</text>
      </g>
      
      <!-- CORE 1 (Top-Right) -->
      <g id="cpu-core-1">
        <rect class="cpu-core" x="98" y="30" width="64" height="75" rx="3" />
        <text x="130" y="47" fill="#93a1a1" font-family="monospace" font-size="10" font-weight="bold" text-anchor="middle">CORE 1</text>
        <rect x="102" y="58" width="56" height="38" fill="#002b36" opacity="0.3" rx="2" />
      </g>
      
      <!-- CORE 2 (Middle-Left) -->
      <g id="cpu-core-2">
        <rect class="cpu-core" x="28" y="112" width="62" height="75" rx="3" />
        <text x="59" y="129" fill="#93a1a1" font-family="monospace" font-size="10" font-weight="bold" text-anchor="middle">CORE 2</text>
        <rect x="32" y="140" width="54" height="38" fill="#002b36" opacity="0.3" rx="2" />
      </g>
      
      <!-- CORE 3 (Middle-Right) -->
      <g id="cpu-core-3">
        <rect class="cpu-core" x="98" y="112" width="64" height="75" rx="3" />
        <text x="130" y="129" fill="#93a1a1" font-family="monospace" font-size="10" font-weight="bold" text-anchor="middle">CORE 3</text>
        <rect x="102" y="140" width="56" height="38" fill="#002b36" opacity="0.3" rx="2" />
      </g>
      
      <!-- Cache L2 Text Helper (Rendered beautifully over the core boundaries) -->
      <text x="95" y="103" fill="#2aa198" font-family="monospace" font-size="9" font-weight="bold" text-anchor="middle">⚡ CACHE L2 (CPU DIE) ⚡</text>

      <!-- Inner CPU Core interconnecting data pathways (L3 -> L2 -> L1 -> Registers) -->
      <path id="bus-cpu-internal" class="mobo-bus" d="M 95 195 L 95 110 L 80 110 L 80 100" opacity="0.6" stroke-width="1.5" />

      <!-- Label -->
      <text x="95" y="278" fill="#93a1a1" font-family="monospace" font-size="12" font-weight="bold" text-anchor="middle">CPU (MULTI-CORE)</text>
    </g>
  </g>
</svg>
