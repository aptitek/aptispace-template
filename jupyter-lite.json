{
  "jupyter-lite-schema-version": 0,
  "apps": {
    "lab": {
      "name": "Notebook",
      "version": "1.0.0",
      "logo": false
    }
  },
  "settings": {
    "@jupyterlab/apputils-extension:themes": {
      "theme": "JupyterLab Light"
    },
    "@jupyterlab/notebook-extension:tracker": {
      "codeCellConfig": {
        "lineNumbers": true,
        "fontFamily": "Recursive, monospace"
      }
    }
  }
}